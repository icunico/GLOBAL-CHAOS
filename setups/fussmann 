		    for it, tx in enumerate(taux):
		        try:
		            H[it], C[it] = od.complexity_entropy(T, taux=tx, dx=6)
		#            print(f"Specie {iv} - taux={tx}: H={H[it]}, C={C[it]}")
		        except:
		            H[it], C[it] = np.nan, np.nan  # Gestione errori

